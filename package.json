  "peerDependencies": {
    "react": "^19",
    "rxjs": "^7"
  },
  "devDependencies": {
    "@docusaurus/core": "3.9.2",
    "@docusaurus/preset-classic": "3.9.2",
    "@goncharovv/eslint-config": "1.2.2",
    "@goncharovv/layout": "0.2.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "eslint": "9.39.4",
    "prism-react-renderer": "1.3.5",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-rxjs-toolbox": "0.1.1",
    "rxjs": "7.8.2",
    "tsup": "8.5.1",
    "vite": "8.0.0",
    "vitepress": "1.6.4"
  }
